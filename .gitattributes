* text=auto

# Keep source and content files normalized as LF across Windows/Linux.
*.md text eol=lf
*.py text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.svg text eol=lf
*.txt text eol=lf

# Windows-native scripts can keep CRLF when needed.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets should never be line-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
